# ============================================
# INDAH SEAFOOD - Environment Variables
# Copy ini jadi .env.local dan isi nilainya
# ============================================

# --- Next Auth ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here-generate-with-openssl-rand-base64-32

# --- Google OAuth ---
# Buat di https://console.cloud.google.com/
# Enable Google OAuth 2.0 → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Supabase ---
# Buat project di https://supabase.com/dashboard
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...your-service-role-key   # RAHASIA! Jangan expose ke client

# --- Midtrans (Sandbox) ---
# Daftar di https://dashboard.sandbox.midtrans.com/
# Settings → Access Keys
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=false

# --- GoSend API (via GoAPIx / GoPay Partner) ---
# Atau gunakan GrabExpress API
# https://developer.goapix.com/
GOSEND_CLIENT_ID=your-gosend-client-id
GOSEND_CLIENT_SECRET=your-gosend-client-secret
GOSEND_API_URL=https://api.sandbox.goapix.com

# --- App Config ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STORE_NAME=Indah Seafood
NEXT_PUBLIC_STORE_PHONE=+62812-3456-7890
NEXT_PUBLIC_STORE_ADDRESS=Jl. Nelayan No. 1, Jakarta Utara
NEXT_PUBLIC_STORE_LAT=-6.1351
NEXT_PUBLIC_STORE_LNG=106.8133
